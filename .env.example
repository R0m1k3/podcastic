# Backend Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# MongoDB Configuration
MONGODB_URI=mongodb://mongo:27017/podcastic
MONGODB_USER=podcastic
MONGODB_PASSWORD=podcastic_dev

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Podcast API (PodcastIndex)
PODCAST_INDEX_API_KEY=your_podcast_index_api_key
PODCAST_INDEX_API_SECRET=your_podcast_index_secret

# Frontend Configuration
VITE_API_URL=http://localhost:5000/api
