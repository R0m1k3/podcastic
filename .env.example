# Backend Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# MongoDB Configuration
MONGODB_URI=mongodb://mongo:27017/podcastic
MONGODB_USER=podcastic
MONGODB_PASSWORD=podcastic_dev

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Podcast API (PodcastIndex) - OPTIONAL but recommended for search feature
# Get free API keys at: https://podcastindex-api.com/
# These enable podcast discovery and search functionality
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# Frontend Configuration (only needed for local dev without Docker)
# In Docker, the frontend is served by the backend itself — no VITE_API_URL needed
VITE_API_URL=/api
